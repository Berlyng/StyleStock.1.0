@using StyleStock.common.DTOS
@model UpdatePurchaseDetailDTO

@{
    ViewData["Title"] = "Actualizar Detalle de Compra";
}

<h1>Actualizar Detalle de Compra</h1>

<form method="post">
    <div class="form-group">
        <label for="ProductId">Producto</label>
        <select class="form-control" asp-for="ProductId" asp-items="ViewBag.Products" disabled>
            <option value="">Seleccione un producto</option>
        </select>
        <span asp-validation-for="ProductId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="Quantity">Cantidad</label>
        <input type="number" class="form-control" asp-for="Quantity" min="1" required />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="UnitPrice">Precio Unitario</label>
        <input type="number" class="form-control" asp-for="UnitPrice" step="0.01" required />
        <span asp-validation-for="UnitPrice" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-warning">Actualizar Detalle</button>
    <a asp-action="Details" asp-route-id="@ViewBag.PurchaseId" class="btn btn-secondary">Cancelar</a>
</form>
