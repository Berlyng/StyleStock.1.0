@using StyleStock.domain.DTOS
@model List<CategoryDTO>
@{
	ViewData["Title"] = " Lista de Categorias";
}

<div class="row">
	<div class="col-8">
		<h1 class="text-black text-center">Lista de Categorias</h1>
		<a class="btn btn-primary mb-3" asp-controller="Category" asp-action="Create">Nueva Categoria</a>
		<table class="table table-bordered">
			<thead>
				<tr>
					<th scope="col">ID</th>
					<th scope="col">Nombre De Categoria</th>
					<th scope="col">Descripcion</th>
				</tr>
			</thead>
			@foreach(var item in Model)
			{
				<tbody>
					<tr>
						<td>@item.CategoryId</td>
						<td>@item.Name</td>
						<td>@item.Description</td>
						<td>
							<a asp-controller="Category"
							asp-action="Update"
							asp-route-id ="@item.CategoryId"
							class="btn btn-success mb-3">Editar</a>
						</td>

						<td>
							<a asp-controller="Category"
							   asp-action="Delete"
							   asp-route-id="@item.CategoryId"
							   class="btn btn-danger mb-3">Eliminar</a>
						</td>
					</tr>
				</tbody>
				
			}
		</table>
	</div>
</div>
